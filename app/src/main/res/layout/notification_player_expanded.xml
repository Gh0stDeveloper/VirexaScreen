<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_notification_panel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_notification_logo"
            android:padding="14dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_notification_playback"
                android:scaleType="centerInside"
                android:contentDescription="@null" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/notification_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/notification_album"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/notification_favorite"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_notification_button"
            android:padding="9dp"
            android:src="@drawable/ic_notification_favorite_outline"
            android:scaleType="centerInside"
            android:contentDescription="@null"
            android:focusable="true"
            android:clickable="true"
            android:adjustViewBounds="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/notification_time_current"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:includeFontPadding="false" />

        <ProgressBar
            android:id="@+id/notification_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/bg_notification_progress"
            android:indeterminate="false" />

        <TextView
            android:id="@+id/notification_time_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <ImageButton
            android:id="@+id/notification_seek_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_notification_button"
            android:padding="9dp"
            android:src="@drawable/ic_notification_seek_back"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <ImageButton
            android:id="@+id/notification_seek_forward"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_notification_button"
            android:padding="9dp"
            android:src="@drawable/ic_notification_seek_forward"
            android:scaleType="centerInside"
            android:contentDescription="@null" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="14dp">

        <ImageButton
            android:id="@+id/notification_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_notification_button"
            android:padding="10dp"
            android:src="@drawable/ic_notification_previous"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <ImageButton
            android:id="@+id/notification_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_notification_button_active"
            android:padding="14dp"
            android:src="@drawable/ic_notification_playback"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <ImageButton
            android:id="@+id/notification_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_notification_button"
            android:padding="10dp"
            android:src="@drawable/ic_notification_next"
            android:scaleType="centerInside"
            android:contentDescription="@null" />

        <ImageButton
            android:id="@+id/notification_stop"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_notification_button"
            android:padding="10dp"
            android:src="@drawable/ic_notification_stop"
            android:scaleType="centerInside"
            android:contentDescription="@null" />
    </LinearLayout>
</LinearLayout>
